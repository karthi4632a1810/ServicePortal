# Copy to .env in the project root for docker compose:
#   copy .env.docker.example .env
#
# HRMS credentials can also live in backend/.env (Docker loads both files).

JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:3000
DEFAULT_EMPLOYEE_PASSWORD=mapims

# HRMS MySQL — required for staff ID lookup / autofill
HRMS_DB_HOST=your-mysql-host.example.com
HRMS_DB_PORT=3306
HRMS_DB_USER=your_db_user
HRMS_DB_PASSWORD=your_db_password
HRMS_DB_NAME=your_db_name
HRMS_DB_TABLE=staff_profile_tb
