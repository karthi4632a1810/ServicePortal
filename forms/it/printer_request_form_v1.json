{
  "id": "form-it-printer-request",
  "title": "Printer Request Form",
  "department": "Information Technology",
  "icon": "Monitor",
  "description": "Request printer access or a new printer assignment for staff at OmSakthi Adhiparasakthi Hospitals.",
  "category": "Forms",
  "version": 1,
  "estimatedTime": "2-3 business days",
  "slaHours": 72,
  "active": false,
  "md_approve": true,
  "workflowTemplateId": "wf-hod-then-processor",
  "fields": [
    {
      "id": "hrms-staff-id",
      "type": "text",
      "label": "Staff ID",
      "required": true,
      "placeholder": "e.g. 60464",
      "width": "full",
      "hrmsSource": "staff_id",
      "helpText": "Your staff ID — details load automatically from records."
    },
    {
      "id": "f3",
      "type": "section_title",
      "label": "Printer Request Details",
      "width": "full"
    },
    {
      "id": "f4",
      "type": "text",
      "label": "Name",
      "required": true,
      "width": "full",
      "placeholder": "Enter your full name"
    },
    {
      "id": "f6",
      "type": "dropdown",
      "label": "Department",
      "hrmsSource": "department",
      "required": true,
      "width": "half",
      "placeholder": "Select department",
      "options": []
    },
    {
      "id": "f7",
      "type": "dropdown",
      "label": "Designation",
      "hrmsSource": "designation",
      "required": true,
      "width": "half",
      "placeholder": "Select designation",
      "options": []
    },
    {
      "id": "f8",
      "type": "date",
      "label": "Date of Joining",
      "required": true,
      "width": "half"
    },
    {
      "id": "f10",
      "type": "phone",
      "label": "CUG No.",
      "width": "half",
      "placeholder": "Closed User Group number (if applicable)",
      "helpText": "Official CUG mobile number, if assigned"
    },
    {
      "id": "f11",
      "type": "section_title",
      "label": "Printer Information",
      "width": "full"
    },
    {
      "id": "f12",
      "type": "dropdown",
      "label": "Request Type",
      "required": true,
      "width": "half",
      "options": [
        {
          "label": "New Printer Assignment",
          "value": "new_printer"
        },
        {
          "label": "Access to Existing Printer",
          "value": "printer_access"
        },
        {
          "label": "Printer Relocation",
          "value": "relocation"
        },
        {
          "label": "Printer Repair / Replacement",
          "value": "repair"
        }
      ]
    },
    {
      "id": "f13",
      "type": "text",
      "label": "Printer Location / Ward",
      "required": true,
      "width": "half",
      "placeholder": "e.g. OPD Block, 2nd Floor Nursing Station"
    },
    {
      "id": "f14",
      "type": "dropdown",
      "label": "Printer Type",
      "width": "half",
      "options": [
        {
          "label": "Network Printer",
          "value": "network"
        },
        {
          "label": "Desktop Printer",
          "value": "desktop"
        },
        {
          "label": "Multifunction (Print/Scan)",
          "value": "mfp"
        },
        {
          "label": "Label Printer",
          "value": "label"
        }
      ]
    },
    {
      "id": "f15",
      "type": "textarea",
      "label": "Reason for Request",
      "required": true,
      "width": "full",
      "placeholder": "Explain why the printer is required..."
    },
    {
      "id": "f16",
      "type": "textarea",
      "label": "Remarks",
      "width": "full",
      "placeholder": "Any additional details for IT..."
    },
    {
      "id": "f17",
      "type": "file",
      "label": "Attach Supporting Document",
      "width": "full",
      "helpText": "Optional: HOD approval or supporting document"
    }
  ],
  "departmentId": "14"
}
