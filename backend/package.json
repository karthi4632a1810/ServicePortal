{
  "name": "service-portal-backend",
  "version": "1.0.0",
  "description": "Service Portal REST API and Workflow Engine",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "main": "src/index.js",
  "scripts": {
    "start": "node ../scripts/kill-port.mjs 5000 && node src/index.js",
    "dev": "node ../scripts/kill-port.mjs 5000 && node --watch src/index.js",
    "seed": "node src/seeds/seed.js",
    "seed:users": "node src/seeds/syncUsers.js",
    "seed:superadmin": "node src/seeds/superadmin.js",
    "clear:requests": "node src/seeds/clearRequests.js",
    "sync:forms": "node src/seeds/syncForms.js",
    "seed:mongo": "node scripts/seedMongoDb.js",
    "test:hrms": "node scripts/test-hrms-db.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.5",
    "nodemailer": "^6.9.14",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  }
}
