# Production — paper.mapims.edu.in
# On VPS:  cp .env.production.example .env   then set JWT_SECRET

# --- Public site (required for HTTPS) ---
DOMAIN=paper.mapims.edu.in
ACME_EMAIL=it@mapims.edu.in
CORS_ORIGIN=https://paper.mapims.edu.in

# Hostinger shared Docker — app port (8093 is free; 27017/5000/3000 are taken by mrd_cl)
APP_PORT=8093

# --- Security (use a long random string — do not commit real .env) ---
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=8h

# --- App ---
DEFAULT_EMPLOYEE_PASSWORD=mapims

# --- HRMS MySQL ---
HRMS_DB_HOST=162.240.58.140
HRMS_DB_PORT=3306
HRMS_DB_USER=mapimson_paperzero
HRMS_DB_PASSWORD=your_hrms_password_here
HRMS_DB_NAME=mapimson_cis2022
HRMS_DB_TABLE=staff_profile_tb
