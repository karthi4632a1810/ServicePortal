# Copy on VPS:  cp .env.production.example .env
# Then edit values below before first deploy.

# --- Public site (required for HTTPS) ---
DOMAIN=portal.yourhospital.com
ACME_EMAIL=admin@yourhospital.com
CORS_ORIGIN=https://portal.yourhospital.com

# --- Security (generate a long random string) ---
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=8h

# --- App ---
DEFAULT_EMPLOYEE_PASSWORD=mapims

# --- HRMS MySQL (same as backend/.env) ---
HRMS_DB_HOST=your-mysql-host
HRMS_DB_PORT=3306
HRMS_DB_USER=your_db_user
HRMS_DB_PASSWORD=your_db_password
HRMS_DB_NAME=your_db_name
HRMS_DB_TABLE=staff_profile_tb
